{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Current Python File in New Terminal",
      "type": "shell",
      "command": "python3",
      "args": ["${file}"],
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "panel": "new",
        "reveal": "always",
        "focus": false,
        "clear": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}